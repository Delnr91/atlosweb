# ATLOS WEB — variables de entorno
# =================================
# IMPORTANTE: la GROQ_API_KEY vive SOLO en el servidor (función serverless
# /api/chat). NUNCA la pongas en el frontend ni con prefijo VITE_ — eso la
# expondría al público en el navegador.

# Groq (opcional). Si falta, el chat usa solo la base de preguntas local.
GROQ_API_KEY=

# Modelo de Groq a usar (opcional)
GROQ_MODEL=openai/gpt-oss-120b
